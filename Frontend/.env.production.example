# Variáveis de Ambiente - Produção
# Este arquivo será usado durante o build de produção (npm run build)

# ⚠️ IMPORTANTE: Preencha com os valores reais após criar os recursos AWS

# URL do backend (EC2)
# Após criar o EC2, substitua pelo IP público
# Exemplo: http://3.123.45.67
VITE_API_URL=http://SEU-IP-DO-EC2-AQUI/api/v1

# Google reCAPTCHA v3 Site Key
# Obtenha em: https://www.google.com/recaptcha/admin
# VITE_RECAPTCHA_SITE_KEY=sua-chave-site-aqui

# Anthropic API Key (se usar no frontend)
# Obtenha em: https://console.anthropic.com/
# VITE_ANTHROPIC_API_KEY=sua-chave-aqui

# Ambiente
NODE_ENV=production
